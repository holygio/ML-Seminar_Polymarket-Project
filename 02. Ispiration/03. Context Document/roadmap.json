                    "code": "@app.get(\"/health\")\ndef health():\n    \"\"\"\n    Returns last pipeline run metadata.\n    Frontend polls this for the 'last updated' indicator.\n    \"\"\"\n    path = DATA_DIR / \"last_run.json\"\n    if not path.exists():\n        return {\n            \"status\":        \"no_data\",\n            \"message\":       \"Pipeline has never run\",\n            \"timestamp\":     None,\n            \"assets_ok\":     [],\n            \"assets_failed\": [],\n        }\n\n    with open(path) as f:\n        data = json.load(f)\n\n    # calculate how stale the data is\n    last_run_dt = datetime.fromisoformat(data[\"timestamp\"].replace(\"Z\", \"+00:00\"))\n    hours_ago   = (datetime.utcnow() - last_run_dt.replace(tzinfo=None)).total_seconds() / 3600\n    is_stale    = hours_ago > 26  # more than 26 hours = missed a daily run\n\n    return {\n        \"status\":        \"stale\" if is_stale else \"ok\",\n        \"timestamp\":     data[\"timestamp\"],\n        \"date\":          data.get(\"date\"),\n        \"hours_ago\":     round(hours_ago, 1),\n        \"assets_ok\":     data.get(\"assets_ok\", []),\n        \"assets_failed\": data.get(\"assets_failed\", []),\n        \"panel_rows\":    data.get(\"panel_rows\"),\n        \"signals_rows\":  data.get(\"signals_rows\"),\n    }"
                },
                {
                    "step": "Step 2.4",
                    "title": "GET /api/signals/today",
                    "code": "@app.get(\"/api/signals/today\")\ndef signals_today():\n    \"\"\"\n    Returns one signal object per asset for today's pre-open snapshot.\n    Used by: Page 2 signal metrics block, Page 3 heatmap summary stats.\n    \"\"\"\n    df = load_csv(\"signals_today.csv\")\n\n    results = []\n    for _, row in df.iterrows():\n        results.append({\n            \"ticker\":                row[\"ticker\"],\n            \"date\":                  row[\"date\"],\n            \"pre_open_implied_prob\": nan_safe(row.get(\"pre_open_implied_prob\")),\n            \"overnight_prob_change\": nan_safe(row.get(\"overnight_prob_change\")),\n            \"pre_open_pm_volume\":    nan_safe(row.get(\"pre_open_pm_volume\")),\n            \"is_high_liquidity\":     bool(row.get(\"is_high_liquidity\", False)),\n            \"true_sentiment\":        nan_safe(row.get(\"true_sentiment\")),\n            \"abs_sentiment\":         nan_safe(row.get(\"abs_sentiment\")),\n            \"signal_direction\":      row.get(\"signal_direction\", \"UNKNOWN\"),\n            \"signal_quality_score\":  nan_safe(row.get(\"signal_quality_score\")),\n        })\n\n    return {\"data\": results, \"count\": len(results)}"
                },
                {
                    "step": "Step 2.5",
                    "title": "GET /api/asset/{ticker}",
                    "instructions": "This is the most complex endpoint. It serves all three charts on Page 2.",
                    "code": "@app.get(\"/api/asset/{ticker}\")\ndef asset_detail(ticker: str, days: int = Query(default=1, ge=1, le=60)):\n    \"\"\"\n    Returns three time series for a given asset:\n      - probability_series:       PRICE_UP over time (PM probability chart)\n      - stock_series:             stock close price over time (stock chart)\n      - true_sentiment_series:    true_sentiment over time (signal chart)\n\n    Also returns latest_signal from signals_today.csv.\n\n    days parameter controls how many days of history to return.\n    Default = 1 (today only). Set to 7/30/60 for historical views.\n\n    Used by: Page 2 — all three charts + signal metrics block.\n    \"\"\"\n    ticker = ticker.upper()\n    panel  = load_csv(\"panel_15m.csv\")\n\n    # filter by ticker\n    asset_panel = panel[panel[\"KEY\"] == ticker].copy()\n    if asset_panel.empty:\n        raise HTTPException(status_code=404, detail=f\"No data for ticker {ticker}\")\n\n    # parse and filter timestamps\n    asset_panel[\"TIMESTAMP\"] = pd.to_datetime(asset_panel[\"TIMESTAMP\"])\n    cutoff = asset_panel[\"TIMESTAMP\"].max() - pd.Timedelta(days=days)\n    asset_panel = asset_panel[asset_panel[\"TIMESTAMP\"] >= cutoff].copy()\n    asset_panel = asset_panel.sort_values(\"TIMESTAMP\")\n\n    suffix = f\"_{INTRADAY_WINDOW_MINUTES}m\"  # e.g. \"_5m\"\n\n    # ── probability series ───────────────────────────────────────\n    prob_series = []\n    for _, row in asset_panel.iterrows():\n        prob_series.append({\n            \"timestamp\":    row[\"TIMESTAMP\"].isoformat(),\n            \"price_up\":     nan_safe(row.get(\"close_bet\")),\n            \"volume\":       nan_safe(row.get(\"total_volume\")),\n            \"open_bet\":     nan_safe(row.get(\"open_bet\")),\n            \"high_bet\":     nan_safe(row.get(\"high_bet\")),\n            \"low_bet\":      nan_safe(row.get(\"low_bet\")),\n        })\n\n    # ── stock series ─────────────────────────────────────────────\n    close_col = f\"stock_close{suffix}\"\n    stock_series = []\n    for _, row in asset_panel.iterrows():\n        stock_series.append({\n            \"timestamp\": row[\"TIMESTAMP\"].isoformat(),\n            \"close\":     nan_safe(row.get(close_col)),\n        })\n\n    # ── true sentiment series ────────────────────────────────────\n    sentiment_series = []\n    for _, row in asset_panel.iterrows():\n        sentiment_series.append({\n            \"timestamp\":     row[\"TIMESTAMP\"].isoformat(),\n            \"true_sentiment\": nan_safe(row.get(\"true_sentiment\")),\n            \"abs_sentiment\":  nan_safe(row.get(\"abs_sentiment\")),\n            \"bs_neutral_prob\": nan_safe(row.get(\"bs_neutral_prob\")),\n        })\n\n    # ── latest signal ────────────────────────────────────────────\n    try:\n        signals_df   = load_csv(\"signals_today.csv\")\n        signal_row   = signals_df[signals_df[\"ticker\"] == ticker]\n        latest_signal = signal_row.iloc[0].to_dict() if not signal_row.empty else {}\n    except Exception:\n        latest_signal = {}\n\n    return {\n        \"ticker\":              ticker,\n        \"days\":                days,\n        \"row_count\":           len(asset_panel),\n        \"latest_signal\":       latest_signal,\n        \"probability_series\":  prob_series,\n        \"stock_series\":        stock_series,\n        \"true_sentiment_series\": sentiment_series,\n    }"
                },
                {
                    "step": "Step 2.6",
                    "title": "GET /api/heatmap",
                    "code": "@app.get(\"/api/heatmap\")\ndef heatmap(days: int = Query(default=30, ge=7, le=60)):\n    \"\"\"\n    Returns daily alignment quadrant per asset per day.\n    Each entry has: ticker, date, prob_direction, price_direction,\n                    volume, quadrant (green/red/yellow/gray)\n\n    Quadrant logic:\n      green  = prob up   AND price up\n      red    = prob down AND price down\n      yellow = diverge   AND volume >= threshold\n      gray   = low volume OR move too small to be directional\n\n    Used by: Page 3 — alignment grid.\n    \"\"\"\n    panel = load_csv(\"panel_15m.csv\")\n    panel[\"TIMESTAMP\"] = pd.to_datetime(panel[\"TIMESTAMP\"])\n\n    cutoff = panel[\"TIMESTAMP\"].max() - pd.Timedelta(days=days)\n    panel  = panel[panel[\"TIMESTAMP\"] >= cutoff].copy()\n\n    # derive date column (NY date)\n    panel[\"date\"] = panel[\"TIMESTAMP\"].dt.date.astype(str)\n\n    suffix    = f\"_{INTRADAY_WINDOW_MINUTES}m\"\n    close_col = f\"stock_close{suffix}\"\n\n    results = []\n\n    for (ticker, date_str), group in panel.groupby([\"KEY\", \"date\"]):\n        group = group.sort_values(\"TIMESTAMP\")\n\n        if len(group) < 2:\n            continue\n\n        # probability direction: compare last pre-open prob to midnight prob\n        first_prob = group[\"open_bet\"].iloc[0]\n        last_prob  = group[\"close_bet\"].iloc[-1]\n        prob_change   = last_prob - first_prob\n        prob_direction = 1 if prob_change > 0 else -1\n\n        # price direction: compare first and last close in the window\n        first_close = group[close_col].iloc[0]\n        last_close  = group[close_col].iloc[-1]\n\n        if pd.isna(first_close) or pd.isna(last_close) or first_close == 0:\n            continue\n\n        price_move  = (last_close - first_close) / first_close\n        price_direction = 1 if price_move > 0 else -1\n\n        volume = group[\"total_volume\"].sum()\n\n        # quadrant assignment\n        move_too_small = abs(price_move) < HEATMAP_MIN_MOVE\n        low_liquidity  = volume < LIQUIDITY_THRESHOLD\n\n        if low_liquidity or move_too_small:\n            quadrant = \"gray\"\n        elif prob_direction == 1 and price_direction == 1:\n            quadrant = \"green\"\n        elif prob_direction == -1 and price_direction == -1:\n            quadrant = \"red\"\n        else:\n            quadrant = \"yellow\"\n\n        results.append({\n            \"ticker\":          ticker,\n            \"date\":            date_str,\n            \"prob_direction\":  prob_direction,\n            \"price_direction\": price_direction,\n            \"prob_change\":     round(prob_change, 4),\n            \"price_move\":      round(price_move, 4),\n            \"volume\":          round(volume, 2),\n            \"quadrant\":        quadrant,\n        })\n\n    return {\n        \"days\":   days,\n        \"count\":  len(results),\n        \"data\":   results,\n    }"
                },
                {
                    "step": "Step 2.7",
                    "title": "Run and test the API",
                    "commands": "cd backend\nuvicorn api.server:app --reload --port 8000",
                    "instructions": "Open http://localhost:8000/docs in a browser. You get an auto-generated Swagger UI. Test every endpoint in this order:\n\n/health — should return status: ok with your last run timestamp\n/api/signals/today — should return 8 objects\n/api/asset/AAPL — should return three series arrays\n/api/asset/AAPL?days=7 — should return more rows than days=1\n/api/heatmap?days=30 — should return ~240 objects (8 assets × 30 days)\n/api/asset/INVALID — should return 404\nShut down the API, delete data/last_run.json, restart — /health should return status: no_data\nDo not touch the frontend until all seven of these pass."
                }
            ]
        },

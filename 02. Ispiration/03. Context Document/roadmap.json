                    "code_new_functions": "def build_signals_today(df_15m: pd.DataFrame, target_date=None) -> pd.DataFrame:\n    \"\"\"\n    Given the full 15-min windowed panel, return one row per asset\n    representing the pre-open snapshot for target_date.\n    \n    The firewall is 09:30 AM NY time — only data before this is used.\n    This is what signals_today.csv will contain.\n    \n    Parameters\n    ----------\n    df_15m      : output of check_lead_lag()\n    target_date : date to build signals for; defaults to today\n    \n    Returns\n    -------\n    DataFrame with one row per asset and these columns:\n        ticker, date, pre_open_implied_prob, overnight_prob_change,\n        pre_open_pm_volume, true_sentiment, abs_sentiment,\n        is_high_liquidity, signal_direction, signal_quality_score\n    \"\"\"\n    if target_date is None:\n        target_date = dt.now(pytz.timezone('America/New_York')).date()\n\n    ny_tz = pytz.timezone('America/New_York')\n\n    # firewall: 09:30 AM NY on target_date\n    firewall_dt = ny_tz.localize(\n        dt.combine(target_date, dt.min.time().replace(\n            hour=FIREWALL_HOUR_NY, minute=FIREWALL_MINUTE_NY))\n    ).astimezone(pytz.UTC)\n\n    midnight_dt = ny_tz.localize(\n        dt.combine(target_date, dt.min.time())\n    ).astimezone(pytz.UTC)\n\n    # filter to today, before firewall\n    ts = pd.to_datetime(df_15m['TIMESTAMP'])\n    if ts.dt.tz is None:\n        ts = ts.dt.tz_localize('UTC')\n    else:\n        ts = ts.dt.tz_convert('UTC')\n\n    mask = (ts >= midnight_dt) & (ts < firewall_dt)\n    today = df_15m[mask].copy()\n\n    if today.empty:\n        return pd.DataFrame()\n\n    rows = []\n    for ticker, group in today.groupby('KEY'):\n        group = group.sort_values('TIMESTAMP')\n\n        pre_open_implied_prob = group['close_bet'].iloc[-1]\n\n        midnight_prob = group['open_bet'].iloc[0]\n        overnight_prob_change = pre_open_implied_prob - midnight_prob\n\n        pre_open_pm_volume = group['total_volume'].sum()\n        true_sentiment     = group['true_sentiment'].iloc[-1]\n        abs_sentiment      = abs(true_sentiment)\n        is_high_liquidity  = pre_open_pm_volume >= LIQUIDITY_THRESHOLD\n        signal_direction   = 'UP' if true_sentiment > 0 else 'DOWN'\n        signal_quality     = _compute_signal_quality(\n            volume=pre_open_pm_volume,\n            abs_sentiment=abs_sentiment\n        )\n\n        rows.append({\n            'ticker':                ticker,\n            'date':                  str(target_date),\n            'pre_open_implied_prob': round(pre_open_implied_prob, 4),\n            'overnight_prob_change': round(overnight_prob_change, 4),\n            'pre_open_pm_volume':    round(pre_open_pm_volume, 2),\n            'true_sentiment':        round(true_sentiment, 4),\n            'abs_sentiment':         round(abs_sentiment, 4),\n            'is_high_liquidity':     is_high_liquidity,\n            'signal_direction':      signal_direction,\n            'signal_quality_score':  signal_quality,\n        })\n\n    return pd.DataFrame(rows)\n\n\ndef _compute_signal_quality(volume: float, abs_sentiment: float) -> float:\n    \"\"\"\n    Score signal quality 0–10 based on available fields.\n    Expand this when spread and depth data are available.\n    \n    Currently scores on:\n      - Volume:     0–4 points\n      - Conviction: 0–4 points  (abs_sentiment percentile proxy)\n      - Baseline:   2 points    (always given if data exists)\n    \"\"\"\n    score = 2.0  # baseline: data exists\n\n    # volume score (0–4)\n    if volume >= SQ_VOLUME_HIGH:\n        score += 4\n    elif volume >= SQ_VOLUME_MED:\n        score += 2\n    else:\n        score += 0\n\n    # conviction score (0–4)\n    # abs_sentiment > 0.05 is high conviction based on empirical distribution\n    if abs_sentiment >= 0.05:\n        score += 4\n    elif abs_sentiment >= 0.02:\n        score += 2\n    else:\n        score += 0\n\n    return round(score, 1)"

                    "title": "Page file: app/asset/[ticker]/page.tsx",
                    "code": "// frontend/app/asset/[ticker]/page.tsx\n\nimport { fetchAsset, fetchSignalsToday } from '@/lib/api'\nimport { ALL_TICKERS } from '@/lib/types'\nimport AssetHeader       from '@/components/asset/AssetHeader'\nimport ProbabilityChart  from '@/components/asset/ProbabilityChart'\nimport StockChart        from '@/components/asset/StockChart'\nimport TrueSentimentChart from '@/components/asset/TrueSentimentChart'\nimport SignalMetricsBlock from '@/components/asset/SignalMetricsBlock'\n\nexport function generateStaticParams() {\n  return ALL_TICKERS.map(t => ({ ticker: t }))\n}\n\nexport default async function AssetPage({\n  params,\n  searchParams,\n}: {\n  params:       { ticker: string }\n  searchParams: { days?: string }\n}) {\n  const ticker = params.ticker.toUpperCase()\n  const days   = parseInt(searchParams.days ?? '1', 10)\n\n  let data\n  try {\n    data = await fetchAsset(ticker, days)\n  } catch (e: any) {\n    return (\n      <div style={{ color: 'var(--red)', padding: '40px' }}>\n        Failed to load data for {ticker}: {e.message}\n      </div>\n    )\n  }\n\n  return (\n    <div style={{ display: 'flex', flexDirection: 'column', gap: '24px' }}>\n\n      <AssetHeader\n        ticker={ticker}\n        overnightChange={data.latest_signal?.overnight_prob_change ?? null}\n        signalDirection={data.latest_signal?.signal_direction ?? null}\n        impliedProb={data.latest_signal?.pre_open_implied_prob ?? null}\n        days={days}\n      />\n\n      {/* Charts row */}\n      <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '16px' }}>\n        <ProbabilityChart data={data.probability_series} />\n        <StockChart       data={data.stock_series} />\n      </div>\n\n      {/* True sentiment — full width */}\n      <TrueSentimentChart data={data.true_sentiment_series} />\n\n      {/* Signal metrics */}\n      <SignalMetricsBlock signal={data.latest_signal} />\n\n    </div>\n  )\n}"
                },
                {
                    "step": "Step 4.2",
                    "title": "Component: AssetHeader",
                    "code": "// frontend/components/asset/AssetHeader.tsx\n\ninterface Props {\n  ticker:          string\n  overnightChange: number | null\n  signalDirection: 'UP' | 'DOWN' | null\n  impliedProb:     number | null\n  days:            number\n}\n\nexport default function AssetHeader({\n  ticker, overnightChange, signalDirection, impliedProb, days\n}: Props) {\n\n  const changeColor = overnightChange == null\n    ? 'var(--text-muted)'\n    : overnightChange > 0 ? 'var(--green)' : 'var(--red)'\n\n  const changeStr = overnightChange == null\n    ? '—'\n    : `${overnightChange > 0 ? '+' : ''}${(overnightChange * 100).toFixed(1)}%`\n\n  const probStr = impliedProb == null\n    ? '—'\n    : `${(impliedProb * 100).toFixed(1)}%`\n\n  return (\n    <div style={{\n      background:   'var(--bg-card)',\n      border:       '1px solid var(--border)',\n      borderRadius: '8px',\n      padding:      '20px 24px',\n      display:      'flex',\n      alignItems:   'center',\n      gap:          '32px',\n    }}>\n\n      {/* Ticker */}\n      <div>\n        <div style={{ fontSize: '28px', fontWeight: 800, letterSpacing: '-1px' }}>\n          {ticker}\n        </div>\n        <div style={{ fontSize: '12px', color: 'var(--text-muted)', marginTop: '2px' }}>\n          Up/Down prediction market\n        </div>\n      </div>\n\n      {/* Overnight change */}\n      <div>\n        <div style={{ fontSize: '11px', color: 'var(--text-muted)', marginBottom: '4px' }}>\n          OVERNIGHT CHANGE\n        </div>\n        <div style={{ fontSize: '26px', fontWeight: 700, color: changeColor, fontFamily: 'var(--mono)' }}>\n          {changeStr}\n        </div>\n      </div>\n\n      {/* Implied prob */}\n      <div>\n        <div style={{ fontSize: '11px', color: 'var(--text-muted)', marginBottom: '4px' }}>\n          PRE-OPEN PROB\n        </div>\n        <div style={{ fontSize: '22px', fontWeight: 600, fontFamily: 'var(--mono)' }}>\n          {probStr}\n        </div>\n      </div>\n\n      {/* Signal badge */}\n      {signalDirection && (\n        <div style={{\n          marginLeft:   'auto',\n          background:   signalDirection === 'UP' ? 'var(--green-dim)' : 'var(--red-dim)',\n          border:       `1px solid ${signalDirection === 'UP' ? 'var(--green)' : 'var(--red)'}`,\n          color:        signalDirection === 'UP' ? 'var(--green)' : 'var(--red)',\n          borderRadius: '6px',\n          padding:      '8px 20px',\n          fontSize:     '16px',\n          fontWeight:   700,\n          letterSpacing: '1px',\n        }}>\n          {signalDirection === 'UP' ? '▲ BUY' : '▼ SELL'}\n        </div>\n      )}\n\n    </div>\n  )\n}"
                },
                {
                    "step": "Step 4.3",
                    "title": "Component: ProbabilityChart",
                    "instructions": "This is the most important component. Take your time with the reference lines — they are the visual that explains the paper.",
                    "code": "'use client'\n\nimport {\n  ComposedChart, Area, Bar, XAxis, YAxis, CartesianGrid,\n  Tooltip, ReferenceLine, ResponsiveContainer, Legend\n} from 'recharts'\nimport type { ProbabilityPoint } from '@/lib/types'\n\ninterface Props { data: ProbabilityPoint[] }\n\nfunction formatTime(iso: string) {\n  const d = new Date(iso)\n  return d.toLocaleTimeString('en-US', {\n    hour:   '2-digit',\n    minute: '2-digit',\n    hour12: false,\n    timeZone: 'America/New_York'\n  })\n}\n\nfunction formatTooltipTime(iso: string) {\n  const d = new Date(iso)\n  return d.toLocaleString('en-US', {\n    month:    'short',\n    day:      'numeric',\n    hour:     '2-digit',\n    minute:   '2-digit',\n    hour12:   false,\n    timeZone: 'America/New_York'\n  }) + ' ET'\n}\n\nexport default function ProbabilityChart({ data }: Props) {\n  if (!data || data.length === 0) {\n    return <ChartShell title=\"PM Probability\"><EmptyState /></ChartShell>\n  }\n\n  const chartData = data.map(d => ({\n    ...d,\n    price_up_pct: d.price_up != null ? d.price_up * 100 : null,\n  }))\n\n  // find the timestamps for the reference lines\n  // We look for the first point on or after 09:30 ET and 16:00 ET\n  const marketOpenISO  = findReferenceTime(data, 9, 30)\n  const marketCloseISO = findReferenceTime(data, 16, 0)\n  const midnightISO    = findReferenceTime(data, 0, 0)\n\n  return (\n    <ChartShell title=\"PM Probability\">\n      <ResponsiveContainer width=\"100%\" height={280}>\n        <ComposedChart data={chartData} margin={{ top: 8, right: 16, bottom: 8, left: 0 }}>\n\n          <defs>\n            <linearGradient id=\"probGradient\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n              <stop offset=\"5%\"  stopColor=\"#10b981\" stopOpacity={0.3} />\n              <stop offset=\"95%\" stopColor=\"#10b981\" stopOpacity={0.0} />\n            </linearGradient>\n            <linearGradient id=\"probGradientRed\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n              <stop offset=\"5%\"  stopColor=\"#ef4444\" stopOpacity={0.3} />\n              <stop offset=\"95%\" stopColor=\"#ef4444\" stopOpacity={0.0} />\n            </linearGradient>\n          </defs>\n\n          <CartesianGrid strokeDasharray=\"3 3\" stroke=\"#2a3448\" />\n\n          <XAxis\n            dataKey=\"timestamp\"\n            tickFormatter={formatTime}\n            tick={{ fontSize: 10, fill: '#6b7a8d' }}\n            tickLine={false}\n            axisLine={{ stroke: '#2a3448' }}\n          />\n\n          {/* Left Y axis — probability */}\n          <YAxis\n            yAxisId=\"prob\"\n            domain={[0, 100]}\n            tick={{ fontSize: 10, fill: '#6b7a8d' }}\n            tickFormatter={v => `${v}%`}\n            tickLine={false}\n            axisLine={false}\n          />\n\n          {/* Right Y axis — volume */}\n          <YAxis\n            yAxisId=\"vol\"\n            orientation=\"right\"\n            tick={{ fontSize: 10, fill: '#6b7a8d' }}\n            tickFormatter={v => `$${(v/1000).toFixed(0)}k`}\n            tickLine={false}\n            axisLine={false}\n          />\n\n          {/* 50% reference line */}\n          <ReferenceLine\n            yAxisId=\"prob\"\n            y={50}\n            stroke=\"#6b7a8d\"\n            strokeDasharray=\"4 4\"\n            label={{ value: '50%', fill: '#6b7a8d', fontSize: 10, position: 'insideTopLeft' }}\n          />\n\n          {/* Midnight */}\n          {midnightISO && (\n            <ReferenceLine\n              yAxisId=\"prob\"\n              x={midnightISO}\n              stroke=\"#6b7a8d\"\n              strokeDasharray=\"2 4\"\n              label={{ value: '00:00', fill: '#6b7a8d', fontSize: 9, position: 'insideTopRight' }}\n            />\n          )}\n\n          {/* Market open — 9:30 AM ET */}\n          {marketOpenISO && (\n            <ReferenceLine\n              yAxisId=\"prob\"\n              x={marketOpenISO}\n              stroke=\"#ef4444\"\n              strokeWidth={1.5}\n              label={{ value: 'Market Open', fill: '#ef4444', fontSize: 9, position: 'insideTopRight' }}\n            />\n          )}\n\n          {/* Market close — 4:00 PM ET */}\n          {marketCloseISO && (\n            <ReferenceLine\n              yAxisId=\"prob\"\n              x={marketCloseISO}\n              stroke=\"#f59e0b\"\n              strokeWidth={1.5}\n              label={{ value: 'Market Close', fill: '#f59e0b', fontSize: 9, position: 'insideTopRight' }}\n            />\n          )}\n\n          {/* Volume bars */}\n          <Bar\n            yAxisId=\"vol\"\n            dataKey=\"volume\"\n            fill=\"#3b82f6\"\n            opacity={0.25}\n            radius={[1, 1, 0, 0]}\n          />\n\n          {/* Probability area */}\n          <Area\n            yAxisId=\"prob\"\n            type=\"monotone\"\n            dataKey=\"price_up_pct\"\n            stroke=\"#10b981\"\n            strokeWidth={2}\n            fill=\"url(#probGradient)\"\n            dot={false}\n            activeDot={{ r: 3 }}\n            connectNulls\n          />\n\n          <Tooltip\n            contentStyle={{\n              background: 'var(--bg-card)',\n              border:     '1px solid var(--border)',\n              borderRadius: '6px',\n              fontSize:   '12px',\n            }}\n            formatter={(value: number, name: string) => {\n              if (name === 'price_up_pct') return [`${value?.toFixed(1)}%`, 'PM Probability']\n              if (name === 'volume')        return [`$${value?.toFixed(0)}`, 'Volume']\n              return [value, name]\n            }}\n            labelFormatter={formatTooltipTime}\n          />\n\n        </ComposedChart>\n      </ResponsiveContainer>\n    </ChartShell>\n  )\n}\n\n// ── helpers ──────────────────────────────────────────────────────\n\nfunction findReferenceTime(data: ProbabilityPoint[], hour: number, minute: number) {\n  for (const d of data) {\n    const dt = new Date(d.timestamp)\n    const nyHour = parseInt(\n      dt.toLocaleString('en-US', { hour: 'numeric', hour12: false, timeZone: 'America/New_York' })\n    )\n    const nyMin  = dt.getMinutes()\n    if (nyHour === hour && nyMin >= minute) return d.timestamp\n  }\n  return null\n}\n\nfunction ChartShell({ title, children }: { title: string; children: React.ReactNode }) {\n  return (\n    <div style={{\n      background:   'var(--bg-card)',\n      border:       '1px solid var(--border)',\n      borderRadius: '8px',\n      padding:      '16px',\n    }}>\n      <div style={{ fontSize: '12px', color: 'var(--text-muted)', marginBottom: '12px', fontWeight: 600, letterSpacing: '0.5px' }}>\n        {title.toUpperCase()}\n      </div>\n      {children}\n    </div>\n  )\n}\n\nfunction EmptyState() {\n  return (\n    <div style={{ height: 280, display: 'flex', alignItems: 'center', justifyContent: 'center', color: 'var(--text-muted)' }}>\n      No data available\n    </div>\n  )\n}"
                },
                {
                    "step": "Step 4.4",
                    "title": "Component: StockChart",
                    "code": "'use client'\n\nimport {\n  LineChart, Line, XAxis, YAxis, CartesianGrid,\n  Tooltip, ReferenceLine, ResponsiveContainer\n} from 'recharts'\nimport type { StockPoint } from '@/lib/types'\n\ninterface Props { data: StockPoint[] }\n\nexport default function StockChart({ data }: Props) {\n  if (!data || data.length === 0) {\n    return <ChartShell title=\"Stock Price\"><EmptyState /></ChartShell>\n  }\n\n  // find 9:30 AM ET reference\n  const marketOpenISO = (() => {\n    for (const d of data) {\n      const dt   = new Date(d.timestamp)\n      const nyHr = parseInt(dt.toLocaleString('en-US', {\n        hour: 'numeric', hour12: false, timeZone: 'America/New_York'\n      }))\n      if (nyHr === 9 && dt.getMinutes() >= 30) return d.timestamp\n    }\n    return null\n  })()\n\n  // compute domain with 0.5% padding\n  const closes = data.map(d => d.close).filter((v): v is number => v != null)\n  const minClose = Math.min(...closes)\n  const maxClose = Math.max(...closes)\n  const pad      = (maxClose - minClose) * 0.05\n  const domain   = [minClose - pad, maxClose + pad] as [number, number]\n\n  return (\n    <ChartShell title=\"Stock Price\">\n      <ResponsiveContainer width=\"100%\" height={280}>\n        <LineChart data={data} margin={{ top: 8, right: 16, bottom: 8, left: 0 }}>\n\n          <CartesianGrid strokeDasharray=\"3 3\" stroke=\"#2a3448\" />\n\n          <XAxis\n            dataKey=\"timestamp\"\n            tickFormatter={ts => new Date(ts).toLocaleTimeString('en-US', {\n              hour: '2-digit', minute: '2-digit', hour12: false, timeZone: 'America/New_York'\n            })}\n            tick={{ fontSize: 10, fill: '#6b7a8d' }}\n            tickLine={false}\n            axisLine={{ stroke: '#2a3448' }}\n          />\n\n          <YAxis\n            domain={domain}\n            tickFormatter={v => `$${v.toFixed(0)}`}\n            tick={{ fontSize: 10, fill: '#6b7a8d' }}\n            tickLine={false}\n            axisLine={false}\n          />\n\n          {marketOpenISO && (\n            <ReferenceLine\n              x={marketOpenISO}\n              stroke=\"#ef4444\"\n              strokeWidth={1.5}\n              label={{ value: 'Market Open', fill: '#ef4444', fontSize: 9, position: 'insideTopRight' }}\n            />\n          )}\n\n          <Line\n            type=\"monotone\"\n            dataKey=\"close\"\n            stroke=\"#3b82f6\"\n            strokeWidth={2}\n            dot={false}\n            activeDot={{ r: 3 }}\n            connectNulls\n          />\n\n          <Tooltip\n            contentStyle={{\n              background: 'var(--bg-card)',\n              border:     '1px solid var(--border)',\n              borderRadius: '6px',\n              fontSize:   '12px',\n            }}\n            formatter={(v: number) => [`$${v?.toFixed(2)}`, 'Close']}\n            labelFormatter={ts => new Date(ts).toLocaleString('en-US', {\n              month: 'short', day: 'numeric', hour: '2-digit',\n              minute: '2-digit', hour12: false, timeZone: 'America/New_York'\n            }) + ' ET'}\n          />\n\n        </LineChart>\n      </ResponsiveContainer>\n    </ChartShell>\n  )\n}\n\nfunction ChartShell({ title, children }: { title: string; children: React.ReactNode }) {\n  return (\n    <div style={{\n      background: 'var(--bg-card)', border: '1px solid var(--border)',\n      borderRadius: '8px', padding: '16px',\n    }}>\n      <div style={{ fontSize: '12px', color: 'var(--text-muted)', marginBottom: '12px', fontWeight: 600 }}>\n        {title.toUpperCase()}\n      </div>\n      {children}\n    </div>\n  )\n}\nfunction EmptyState() {\n  return <div style={{ height: 280, display: 'flex', alignItems: 'center', justifyContent: 'center', color: 'var(--text-muted)' }}>No data available</div>\n}"
                },
                {
                    "step": "Step 4.5",
                    "title": "Component: TrueSentimentChart",
                    "code": "'use client'\n\nimport {\n  BarChart, Bar, Cell, XAxis, YAxis, CartesianGrid,\n  Tooltip, ReferenceLine, ResponsiveContainer\n} from 'recharts'\nimport type { SentimentPoint } from '@/lib/types'\n\ninterface Props { data: SentimentPoint[] }\n\nexport default function TrueSentimentChart({ data }: Props) {\n  if (!data || data.length === 0) return null\n\n  return (\n    <div style={{\n      background: 'var(--bg-card)', border: '1px solid var(--border)',\n      borderRadius: '8px', padding: '16px',\n    }}>\n\n      {/* Header with explanation */}\n      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', marginBottom: '12px' }}>\n        <div style={{ fontSize: '12px', color: 'var(--text-muted)', fontWeight: 600 }}>\n          TRUE SENTIMENT (PM PRICE − BLACK-SCHOLES FAIR VALUE)\n        </div>\n        <div style={{ fontSize: '11px', color: 'var(--text-muted)', maxWidth: '320px', textAlign: 'right' }}>\n          Positive = PM more bullish than BS fair value → signal to buy\n        </div>\n      </div>\n\n      <ResponsiveContainer width=\"100%\" height={180}>\n        <BarChart data={data} margin={{ top: 4, right: 16, bottom: 4, left: 0 }}>\n\n          <CartesianGrid strokeDasharray=\"3 3\" stroke=\"#2a3448\" vertical={false} />\n\n          <XAxis\n            dataKey=\"timestamp\"\n            tickFormatter={ts => new Date(ts).toLocaleTimeString('en-US', {\n              hour: '2-digit', minute: '2-digit', hour12: false, timeZone: 'America/New_York'\n            })}\n            tick={{ fontSize: 10, fill: '#6b7a8d' }}\n            tickLine={false}\n            axisLine={{ stroke: '#2a3448' }}\n          />\n\n          <YAxis\n            tick={{ fontSize: 10, fill: '#6b7a8d' }}\n            tickFormatter={v => v.toFixed(2)}\n            tickLine={false}\n            axisLine={false}\n          />\n\n          <ReferenceLine y={0} stroke=\"#6b7a8d\" strokeWidth={1} />\n\n          <Bar dataKey=\"true_sentiment\" radius={[1, 1, 0, 0]}>\n            {data.map((entry, idx) => (\n              <Cell\n                key={idx}\n                fill={(entry.true_sentiment ?? 0) >= 0 ? '#10b981' : '#ef4444'}\n                opacity={0.8}\n              />\n            ))}\n          </Bar>\n\n          <Tooltip\n            contentStyle={{\n              background: 'var(--bg-card)', border: '1px solid var(--border)',\n              borderRadius: '6px', fontSize: '12px',\n            }}\n            formatter={(v: number, name: string) => [v?.toFixed(4), 'True Sentiment']}\n            labelFormatter={ts => new Date(ts).toLocaleString('en-US', {\n              month: 'short', day: 'numeric', hour: '2-digit',\n              minute: '2-digit', hour12: false, timeZone: 'America/New_York'\n            }) + ' ET'}\n          />\n\n        </BarChart>\n      </ResponsiveContainer>\n    </div>\n  )\n}"
                },
                {
                    "step": "Step 4.6",
                    "title": "Component: SignalMetricsBlock",
                    "code": "// frontend/components/asset/SignalMetricsBlock.tsx\nimport type { SignalToday } from '@/lib/types'\n\ninterface Props { signal: SignalToday | null }\n\nexport default function SignalMetricsBlock({ signal }: Props) {\n  if (!signal) return null\n\n  const score    = signal.signal_quality_score ?? 0\n  const scoreColor = score >= 7 ? 'var(--green)' : score >= 4 ? 'var(--yellow)' : 'var(--red)'\n\n  const conviction =\n    signal.abs_sentiment >= 0.05 ? 'HIGH' :\n    signal.abs_sentiment >= 0.02 ? 'MEDIUM' : 'LOW'\n\n  const convictionColor =\n    conviction === 'HIGH' ? 'var(--green)' :\n    conviction === 'MEDIUM' ? 'var(--yellow)' : 'var(--text-muted)'\n\n  return (\n    <div style={{\n      display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '16px',\n    }}>\n\n      {/* Left — PM metrics */}\n      <div style={{\n        background: 'var(--bg-card)', border: '1px solid var(--border)',\n        borderRadius: '8px', padding: '20px',\n      }}>\n        <div style={{ fontSize: '12px', color: 'var(--text-muted)', fontWeight: 600, marginBottom: '16px' }}>\n          PRE-OPEN POLYMARKET METRICS\n        </div>\n\n        <MetricRow label=\"Implied Probability\"\n          value={`${(signal.pre_open_implied_prob * 100).toFixed(1)}%`} />\n\n        <MetricRow label=\"Overnight Change\"\n          value={`${signal.overnight_prob_change > 0 ? '+' : ''}${(signal.overnight_prob_change * 100).toFixed(2)}%`}\n          color={signal.overnight_prob_change > 0 ? 'var(--green)' : 'var(--red)'} />\n\n        <MetricRow label=\"Pre-Open Volume\"\n          value={`$${signal.pre_open_pm_volume.toLocaleString()}`}\n          badge={signal.is_high_liquidity ? { label: 'HIGH LIQ', color: 'var(--green)' } : { label: 'LOW LIQ', color: 'var(--red)' }}\n        />\n\n        <MetricRow label=\"True Sentiment\"\n          value={signal.true_sentiment.toFixed(4)}\n          color={signal.true_sentiment > 0 ? 'var(--green)' : 'var(--red)'}\n        />\n\n        <MetricRow label=\"Signal Conviction\"\n          value={conviction}\n          color={convictionColor}\n        />\n      </div>\n\n      {/* Right — Signal quality score */}\n      <div style={{\n        background: 'var(--bg-card)', border: '1px solid var(--border)',\n        borderRadius: '8px', padding: '20px',\n      }}>\n        <div style={{ fontSize: '12px', color: 'var(--text-muted)', fontWeight: 600, marginBottom: '16px' }}>\n          SIGNAL QUALITY SCORE\n        </div>\n\n        {/* Big score */}\n        <div style={{ display: 'flex', alignItems: 'baseline', gap: '4px', marginBottom: '20px' }}>\n          <span style={{ fontSize: '48px', fontWeight: 800, color: scoreColor, fontFamily: 'var(--mono)' }}>\n            {score.toFixed(1)}\n          </span>\n          <span style={{ fontSize: '20px', color: 'var(--text-muted)' }}>/10</span>\n        </div>\n\n        {/* Score bar */}\n        <div style={{ marginBottom: '16px' }}>\n          <div style={{ background: 'var(--border)', borderRadius: '4px', height: '6px', width: '100%' }}>\n            <div style={{\n              background: scoreColor, borderRadius: '4px',\n              height: '6px', width: `${(score / 10) * 100}%`,\n              transition: 'width 0.4s ease',\n            }} />\n          </div>\n        </div>\n\n        {/* Score components */}\n        <ScoreRow label=\"Volume\"   pass={signal.pre_open_pm_volume >= 500} />\n        <ScoreRow label=\"Liquidity\" pass={signal.is_high_liquidity} />\n        <ScoreRow label=\"Conviction\" pass={signal.abs_sentiment >= 0.02} />\n        <ScoreRow label=\"Data exists\" pass={true} />\n\n      </div>\n    </div>\n  )\n}\n\nfunction MetricRow({ label, value, color, badge }: {\n  label:   string\n  value:   string\n  color?:  string\n  badge?:  { label: string; color: string }\n}) {\n  return (\n    <div style={{\n      display: 'flex', justifyContent: 'space-between', alignItems: 'center',\n      padding: '8px 0', borderBottom: '1px solid var(--border)',\n    }}>\n      <span style={{ fontSize: '13px', color: 'var(--text-muted)' }}>{label}</span>\n      <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>\n        {badge && (\n          <span style={{\n            fontSize: '10px', padding: '2px 6px', borderRadius: '3px',\n            background: badge.color + '22', color: badge.color, fontWeight: 600,\n          }}>\n            {badge.label}\n          </span>\n        )}\n        <span style={{ fontSize: '14px', fontWeight: 600, color: color ?? 'var(--text)', fontFamily: 'var(--mono)' }}>\n          {value}\n        </span>\n      </div>\n    </div>\n  )\n}\n\nfunction ScoreRow({ label, pass }: { label: string; pass: boolean }) {\n  return (\n    <div style={{\n      display: 'flex', justifyContent: 'space-between',\n      padding: '5px 0', fontSize: '13px',\n    }}>\n      <span style={{ color: 'var(--text-muted)' }}>{label}</span>\n      <span style={{ color: pass ? 'var(--green)' : 'var(--red)' }}>\n        {pass ? '✓' : '✗'}\n      </span>\n    </div>\n  )\n}"
                }
            ]
        },
        {
            "phase_name": "Phase 5 — Page 3: Signal Alignment Heatmap",
            "estimated_time": "2 days",
            "steps": [
                {
                    "step": "Step 5.1",
                    "title": "Page file: app/heatmap/page.tsx",
                    "code": "// frontend/app/heatmap/page.tsx\n'use client'\n\nimport { useState, useEffect } from 'react'\nimport { fetchHeatmap } from '@/lib/api'\nimport type { HeatmapEntry, HeatmapResponse } from '@/lib/types'\nimport TimeFilterBar       from '@/components/heatmap/TimeFilterBar'\nimport QuadrantLegend      from '@/components/heatmap/QuadrantLegend'\nimport AlignmentGrid       from '@/components/heatmap/AlignmentGrid'\nimport AlignmentSummaryStats from '@/components/heatmap/AlignmentSummaryStats'\n\nexport default function HeatmapPage() {\n  const [days, setDays]     = useState(30)\n  const [data, setData]     = useState<HeatmapEntry[]>([])\n  const [loading, setLoading] = useState(true)\n  const [error, setError]   = useState<string | null>(null)\n\n  useEffect(() => {\n    setLoading(true)\n    setError(null)\n    fetchHeatmap(days)\n      .then(res => setData(res.data))\n      .catch(e  => setError(e.message))\n      .finally(()=> setLoading(false))\n  }, [days])\n\n  return (\n    <div style={{ display: 'flex', flexDirection: 'column', gap: '20px' }}>\n\n      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>\n        <div>\n          <h1 style={{ fontSize: '20px', fontWeight: 700, marginBottom: '4px' }}>\n            Signal Alignment Heatmap\n          </h1>\n          <p style={{ fontSize: '13px', color: 'var(--text-muted)' }}>\n            Did Polymarket probability direction match stock price direction?\n          </p>\n        </div>\n        <TimeFilterBar selected={days} onChange={setDays} />\n      </div>\n\n      <QuadrantLegend />\n\n      {loading && <LoadingSkeleton />}\n      {error   && <ErrorBanner message={error} />}\n      {!loading && !error && (\n        <>\n          <AlignmentGrid data={data} days={days} />\n          <AlignmentSummaryStats data={data} />\n        </>\n      )}\n\n    </div>\n  )\n}\n\nfunction LoadingSkeleton() {\n  return (\n    <div style={{\n      background: 'var(--bg-card)', border: '1px solid var(--border)',\n      borderRadius: '8px', height: '320px',\n      display: 'flex', alignItems: 'center', justifyContent: 'center',\n      color: 'var(--text-muted)',\n    }}>\n      Loading heatmap...\n    </div>\n  )\n}\n\nfunction ErrorBanner({ message }: { message: string }) {\n  return (\n    <div style={{\n      background: 'var(--red-dim)', border: '1px solid var(--red)',\n      borderRadius: '6px', padding: '12px 16px', color: 'var(--red)',\n    }}>\n      {message}\n    </div>\n  )\n}"
                },
                {
                    "step": "Step 5.2",
                    "title": "Component: TimeFilterBar",
                    "code": "// frontend/components/heatmap/TimeFilterBar.tsx\n\ninterface Props {\n  selected: number\n  onChange: (days: number) => void\n}\n\nconst OPTIONS = [\n  { label: '7D',  days: 7  },\n  { label: '30D', days: 30 },\n  { label: '60D', days: 60 },\n]\n\nexport default function TimeFilterBar({ selected, onChange }: Props) {\n  return (\n    <div style={{ display: 'flex', gap: '4px' }}>\n      {OPTIONS.map(opt => (\n        <button\n          key={opt.days}\n          onClick={() => onChange(opt.days)}\n          style={{\n            padding:      '6px 14px',\n            borderRadius: '5px',\n            border:       '1px solid var(--border)',\n            background:   selected === opt.days ? 'var(--accent)' : 'var(--bg-card)',\n            color:        selected === opt.days ? 'white' : 'var(--text-muted)',\n            fontSize:     '12px',\n            fontWeight:   600,\n            cursor:       'pointer',\n            transition:   'all 0.15s',\n          }}\n        >\n          {opt.label}\n        </button>\n      ))}\n    </div>\n  )\n}"
                },
                {
                    "step": "Step 5.3",
                    "title": "Component: QuadrantLegend",
                    "code": "// frontend/components/heatmap/QuadrantLegend.tsx\n\nconst QUADRANTS = [\n  { color: '#10b981', label: 'Aligned Bullish',  desc: 'Prob ↑ & Price ↑' },\n  { color: '#ef4444', label: 'Aligned Bearish',  desc: 'Prob ↓ & Price ↓' },\n  { color: '#f59e0b', label: 'Divergent',         desc: 'Prob and price disagree' },\n  { color: '#374151', label: 'No Signal',         desc: 'Low volume or small move' },\n]\n\nexport default function QuadrantLegend() {\n  return (\n    <div style={{ display: 'flex', gap: '20px', flexWrap: 'wrap' }}>\n      {QUADRANTS.map(q => (\n        <div key={q.label} style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>\n          <div style={{\n            width: '12px', height: '12px', borderRadius: '2px',\n            background: q.color,\n          }} />\n          <div>\n            <span style={{ fontSize: '12px', fontWeight: 600 }}>{q.label}</span>\n            <span style={{ fontSize: '11px', color: 'var(--text-muted)', marginLeft: '6px' }}>\n              {q.desc}\n            </span>\n          </div>\n        </div>\n      ))}\n    </div>\n  )\n}"
                },
                {
                    "step": "Step 5.4",
                    "title": "Component: AlignmentGrid",
                    "code": "'use client'\nimport { useRouter } from 'next/navigation'\nimport type { HeatmapEntry } from '@/lib/types'\n\ninterface Props {\n  data: HeatmapEntry[]\n  days: number\n}\n\nconst QUADRANT_COLOR = {\n  green:  '#10b981',\n  red:    '#ef4444',\n  yellow: '#f59e0b',\n  gray:   '#374151',\n}\n\nconst TICKERS = ['AAPL','MSFT','NVDA','GOOGL','META','AMZN','NFLX','TSLA']\n\nexport default function AlignmentGrid({ data, days }: Props) {\n  const router = useRouter()\n\n  // get sorted unique dates\n  const allDates = [...new Set(data.map(d => d.date))].sort()\n\n  // build lookup: ticker+date → entry\n  const lookup = new Map<string, HeatmapEntry>()\n  data.forEach(d => lookup.set(`${d.ticker}|${d.date}`, d))\n\n  // for display: shorten dates to MM/DD\n  const formatDate = (iso: string) => {\n    const [, m, d] = iso.split('-')\n    return `${m}/${d}`\n  }\n\n  return (\n    <div style={{\n      background: 'var(--bg-card)', border: '1px solid var(--border)',\n      borderRadius: '8px', padding: '16px', overflowX: 'auto',\n    }}>\n      <table style={{ borderCollapse: 'collapse', width: '100%', minWidth: '600px' }}>\n\n        {/* Date headers */}\n        <thead>\n          <tr>\n            <th style={{ width: '64px', textAlign: 'left', fontSize: '11px', color: 'var(--text-muted)', padding: '0 8px 8px' }}>\n              ASSET\n            </th>\n            {allDates.map(d => (\n              <th key={d} style={{\n                fontSize: '10px', color: 'var(--text-muted)',\n                fontWeight: 400, padding: '0 2px 8px', textAlign: 'center', minWidth: '28px',\n              }}>\n                {formatDate(d)}\n              </th>\n            ))}\n          </tr>\n        </thead>\n\n        <tbody>\n          {TICKERS.map(ticker => (\n            <tr key={ticker}>\n\n              {/* Ticker label — clickable */}\n              <td\n                onClick={() => router.push(`/asset/${ticker}`)}\n                style={{\n                  fontSize: '12px', fontWeight: 700, padding: '3px 8px 3px 0',\n                  cursor: 'pointer', color: 'var(--accent)',\n                }}\n              >\n                {ticker}\n              </td>\n\n              {/* One cell per date */}\n              {allDates.map(date => {\n                const entry = lookup.get(`${ticker}|${date}`)\n                const bg    = entry ? QUADRANT_COLOR[entry.quadrant] : 'var(--bg)'\n                const opacity = entry ? 0.75 : 0.15\n\n                return (\n                  <td key={date} title={entry ? buildTooltip(entry) : 'No data'}>\n                    <div style={{\n                      width: '22px', height: '22px', borderRadius: '3px',\n                      background: bg, opacity,\n                      margin: '2px auto',\n                    }} />\n                  </td>\n                )\n              })}\n\n            </tr>\n          ))}\n        </tbody>\n\n      </table>\n    </div>\n  )\n}\n\nfunction buildTooltip(e: HeatmapEntry): string {\n  return [\n    `${e.ticker} — ${e.date}`,\n    `PM change: ${(e.prob_change * 100).toFixed(1)}%`,\n    `Price move: ${(e.price_move * 100).toFixed(2)}%`,\n    `Volume: $${e.volume.toFixed(0)}`,\n    `Quadrant: ${e.quadrant}`,\n  ].join('\\n')\n}"
                },
                {
                    "step": "Step 5.5",
                    "title": "Component: AlignmentSummaryStats",
                    "code": "import type { HeatmapEntry } from '@/lib/types'\n\ninterface Props { data: HeatmapEntry[] }\n\nexport default function AlignmentSummaryStats({ data }: Props) {\n  if (!data.length) return null\n\n  const nonGray      = data.filter(d => d.quadrant !== 'gray')\n  const aligned      = data.filter(d => d.quadrant === 'green' || d.quadrant === 'red')\n  const highLiq      = data.filter(d => d.volume >= 500)\n  const highLiqAlign = highLiq.filter(d => d.quadrant === 'green' || d.quadrant === 'red')\n\n  const alignRate        = nonGray.length ? aligned.length / nonGray.length : 0\n  const highLiqAlignRate = highLiq.length ? highLiqAlign.length / highLiq.length : 0\n\n  // best and worst asset by alignment rate\n  const byTicker = groupBy(nonGray, d => d.ticker)\n  let bestTicker = '', bestRate = 0\n  let worstTicker = '', worstRate = 1\n\n  Object.entries(byTicker).forEach(([ticker, entries]) => {\n    const rate = entries.filter(e => e.quadrant === 'green' || e.quadrant === 'red').length / entries.length\n    if (rate > bestRate)  { bestRate  = rate;  bestTicker  = ticker }\n    if (rate < worstRate) { worstRate = rate; worstTicker = ticker }\n  })\n\n  return (\n    <div style={{\n      display: 'grid', gridTemplateColumns: 'repeat(4, 1fr)', gap: '12px',\n    }}>\n      <StatCard\n        label=\"Overall Alignment\"\n        value={`${(alignRate * 100).toFixed(0)}%`}\n        sub={`${aligned.length} of ${nonGray.length} directional signals`}\n      />\n      <StatCard\n        label=\"High-Liq Alignment\"\n        value={`${(highLiqAlignRate * 100).toFixed(0)}%`}\n        sub={`volume > $500 only (${highLiq.length} obs)`}\n        highlight\n      />\n      <StatCard\n        label=\"Best Asset\"\n        value={bestTicker}\n        sub={`${(bestRate * 100).toFixed(0)}% alignment rate`}\n        color=\"var(--green)\"\n      />\n      <StatCard\n        label=\"Worst Asset\"\n        value={worstTicker}\n        sub={`${(worstRate * 100).toFixed(0)}% alignment rate`}\n        color=\"var(--red)\"\n      />\n    </div>\n  )\n}\n\nfunction StatCard({ label, value, sub, highlight = false, color }: {\n  label:      string\n  value:      string\n  sub:        string\n  highlight?: boolean\n  color?:     string\n}) {\n  return (\n    <div style={{\n      background:   highlight ? 'var(--bg-hover)' : 'var(--bg-card)',\n      border:       `1px solid ${highlight ? 'var(--accent)' : 'var(--border)'}`,\n      borderRadius: '8px',\n      padding:      '16px',\n    }}>\n      <div style={{ fontSize: '11px', color: 'var(--text-muted)', marginBottom: '8px', fontWeight: 600 }}>\n        {label.toUpperCase()}\n      </div>\n      <div style={{ fontSize: '24px', fontWeight: 800, color: color ?? 'var(--text)', fontFamily: 'var(--mono)' }}>\n        {value}\n      </div>\n      <div style={{ fontSize: '11px', color: 'var(--text-muted)', marginTop: '4px' }}>\n        {sub}\n      </div>\n    </div>\n  )\n}\n\nfunction groupBy<T>(arr: T[], key: (item: T) => string): Record<string, T[]> {\n  return arr.reduce((acc, item) => {\n    const k = key(item)\n    if (!acc[k]) acc[k] = []\n    acc[k].push(item)\n    return acc\n  }, {} as Record<string, T[]>)\n}"
                }
            ]
